  "description": "Model Context Protocol server for Solnk — publish and schedule content to X, Instagram, TikTok, YouTube, Facebook, LinkedIn, Pinterest, Threads, and Bluesky from any MCP client.",
  "license": "MIT",
  "homepage": "https://solnk.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solnk-dev/solnk-mcp.git"
  },
