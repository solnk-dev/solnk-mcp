  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "solnk",
    "social-media",
    "cloudflare-workers"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
